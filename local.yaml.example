# Local AI Configuration Template
#
# Copy this to local.yaml and customize for your machine.
# local.yaml is gitignored - do not commit it.

# Skill and agent collections map local source repos into this repo's shared
# skills/ and agents/ output directories.
#
# `path` points to the source repo root. By default, skills are found at
# {path}/skills/{name} and agents at {path}/agents/{name}.
# Override with `skills_dir` or `agents_dir` for different layouts.
#
# Items can be:
#   - A string: source dir name = symlink name
#   - An object with `source` and `name` when they differ
#
# Collections whose path does not exist are skipped, so you can keep personal
# and work collections in the same local.yaml across machines.

collections:
  # Personal collection - your private reusable skills repo.
  personal:
    path: ~/Repositories/my-ai-skills
    skills:
      - my-skill
      - another-skill
      # - source: reviewer
      #   name: code-review
    agents:
      - my-agent.md
    hooks:
      - my-hook.sh

    # `links:` exposes non-skill content from the collection.
    #
    # `target` must be absolute or ~-prefixed.
    # `source` is normally relative to `path` (the collection repo root);
    # a source starting with `/` or `~` is taken verbatim, which lets a
    # link CHAIN through another already-declared symlink rather than
    # pointing straight at the collection repo.
    #
    # For actively-written config files (e.g. Claude Code's settings.json),
    # prefer a directory symlink one layer up so atomic-write-rename lands
    # inside the symlinked directory and the symlinks above it survive.
    # Read-only scripts can use a direct file symlink without this concern.
    links:
      # === Example: Claude Code settings chain ===
      # 1. Directory symlink so ai/claude/ resolves to the collection's
      #    claude/ directory.
      # - source: claude
      #   target: ~/Repositories/ai/claude
      # 2. File symlink chained through ai/claude/ (absolute source path).
      #    Atomic writes by Claude Code rename inside the resolved
      #    directory, leaving both symlinks above it intact.
      # - source: ~/Repositories/ai/claude/settings.json
      #   target: ~/.claude/settings.json
      # === Example: read-only scripts referenced from settings.json ===
      # statusLine.command and hook commands are paths, not payloads —
      # symlinking them here means peer machines that run sync.sh get
      # the same scripts available at the same well-known paths.
      # - source: claude/statusline.sh
      #   target: ~/.claude/statusline.sh

  # Flat repo example - skills live directly under the repo root.
  # flat-skills:
  #   path: ~/Repositories/my-flat-skills
  #   skills_dir: ""
  #   skills:
  #     - code-review

  # Work collection - uncomment on work machines.
  # work:
  #   path: ~/Repositories/company-ai
  #   skills:
  #     - company-api
  #     - source: dotnet
  #       name: company-dotnet
  #   agents:
  #     - company-agent.md

# Optional machine context used by some skills/prompts. sync.sh does not require
# these sections.

work:
  name: YourCompany
  skills_path: /path/to/yourcompany-ai/skills/
  repositories_root: /path/to/repositories/

paths:
  home: /Users/YourUsername

obsidian:
  vault_path: /path/to/your/obsidian/vault

  # User-defined contexts. Keys are free-form names you choose to match
  # how you mentally separate your notes (some users have one, others
  # have several). Agents enumerate these via
  # skills/obsidian-notes/scripts/context.sh and ask which to use when
  # it can't be inferred from session context. The shape mirrors the
  # daily-context Obsidian plugin's data.json so both stay in sync.
  contexts:
    default:
      daily_folder: 0 Daily Notes
      ai_session_folders:
        - 0 AI Sessions

qdrant:
  collections:
    code: Indexed Git repo source code
    # work: Obsidian work notes
    # personal: Obsidian personal notes
