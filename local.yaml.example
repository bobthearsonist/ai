# Local AI Configuration Template
#
# Copy this to local.yaml and customize for your machine.
# local.yaml is gitignored - do not commit it.

# Skill and agent collections map local source repos into this repo's shared
# skills/ and agents/ output directories.
#
# `path` points to the source repo root. By default, skills are found at
# {path}/skills/{name} and agents at {path}/agents/{name}.
# Override with `skills_dir` or `agents_dir` for different layouts.
#
# Items can be:
#   - A string: source dir name = symlink name
#   - An object with `source` and `name` when they differ
#
# Collections whose path does not exist are skipped, so you can keep personal
# and work collections in the same local.yaml across machines.

collections:
  # Personal collection - your private reusable skills repo.
  personal:
    path: ~/Repositories/my-ai-skills
    skills:
      - my-skill
      - another-skill
      # - source: reviewer
      #   name: code-review
    agents:
      - my-agent.md
    hooks:
      - my-hook.sh

    # `links:` exposes non-skill content from the collection. Use directory
    # symlinks for actively-written configs; file symlinks can be replaced by
    # apps that write through atomic temp-file renames.
    links:
      # - claude
      # - source: claude/statusline.sh
      #   target: ~/.claude/statusline.sh

  # Flat repo example - skills live directly under the repo root.
  # flat-skills:
  #   path: ~/Repositories/my-flat-skills
  #   skills_dir: ""
  #   skills:
  #     - code-review

  # Work collection - uncomment on work machines.
  # work:
  #   path: ~/Repositories/company-ai
  #   skills:
  #     - company-api
  #     - source: dotnet
  #       name: company-dotnet
  #   agents:
  #     - company-agent.md

# Optional machine context used by some skills/prompts. sync.sh does not require
# these sections.

work:
  name: YourCompany
  skills_path: /path/to/yourcompany-ai/skills/
  repositories_root: /path/to/repositories/

paths:
  home: /Users/YourUsername

obsidian:
  vault_path: /path/to/your/obsidian/vault
  personal_daily_folder: 0 Daily Notes
  work_daily_folder: 0 Work/Team Daily Notes

qdrant:
  collections:
    code: Indexed Git repo source code
    # work: Obsidian work notes
    # personal: Obsidian personal notes
