  },
  "edge_classes": {
    "strong-edge": { "description": "Primary causal or dependency relationship", "width": 3, "style": "solid" },
    "default": { "description": "Standard relationship", "width": 2, "style": "solid" },
    "weak-edge": { "description": "Cross-domain or tangential connection", "width": 1, "style": "dashed" }
